<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="TaskPaneApp">

  <Id>A1B2C3D4-E5F6-7890-ABCD-EF1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>CodeForge AI</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>

  <DisplayName DefaultValue="CodeForge AI — PowerPoint" />
  <Description DefaultValue="Ask questions about your slides or generate slide content. 100% offline." />

  <IconUrl DefaultValue="https://raw.githubusercontent.com/OfficeDev/Office-Add-in-samples/main/Samples/hello-world/powerpoint-hello-world/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://raw.githubusercontent.com/OfficeDev/Office-Add-in-samples/main/Samples/hello-world/powerpoint-hello-world/assets/icon-64.png" />
  <SupportUrl DefaultValue="https://github.com/Edu124/Codeforge-ai" />

  <AppDomains>
    <AppDomain>http://localhost:8091</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Presentation" />
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="PowerPointApi" MinVersion="1.3" />
    </Sets>
  </Requirements>

  <DefaultSettings>
    <SourceLocation DefaultValue="http://localhost:8091/taskpane.html" />
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

</OfficeApp>
