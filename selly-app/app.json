{
  "expo": {
    "name": "Selly",
    "slug": "selly-app",
    "version": "1.0.0",
    "sdkVersion": "52.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0a0f",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/085c3fc3-9b68-45ef-a873-c35236d8ff45",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 15000
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.selly.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.selly.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Selly to access your photos to upload product images and media."
        }
      ],
      "expo-document-picker",
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Selly to access your contacts to easily add students and customers."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#7c3aed",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "Selly"
        }
      ],
      "expo-updates"
    ],
    "extra": {
      "eas": {
        "projectId": "085c3fc3-9b68-45ef-a873-c35236d8ff45"
      }
    }
  }
}
