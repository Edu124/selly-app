{
  "manifest_version": 3,
  "name": "CodeForge AI",
  "version": "1.0.0",
  "description": "AI assistant for your browser — powered by CodeForge",
  "permissions": ["sidePanel", "activeTab", "scripting", "tabs", "storage", "alarms"],
  "host_permissions": ["<all_urls>"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open CodeForge AI",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js", "automation-recorder.js", "bot.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://app.powerbi.com/*"],
      "js": ["powerbi-content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
